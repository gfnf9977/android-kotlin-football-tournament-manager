<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/header_gradient"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:gravity="center">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚽ МАТЧ-ЦЕНТР"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/group_border"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏆 ВИБІР КОМАНД"
            android:textSize="12sp"
            android:textColor="#757575"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/spTeam1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/spinner_border"
                android:padding="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" VS "
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="16sp"
                android:padding="8dp"/>

            <Spinner
                android:id="@+id/spTeam2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/spinner_border"
                android:padding="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutLineupButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnSetLineup1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 Склад 1"
            android:backgroundTint="#0288D1"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"
            android:padding="10dp"/>

        <Button
            android:id="@+id/btnSetLineup2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 Склад 2"
            android:backgroundTint="#0288D1"
            android:textColor="@android:color/white"
            android:layout_marginStart="4dp"
            android:padding="10dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnStartMatch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚀 Розпочати гру"
        android:backgroundTint="#2E7D32"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:padding="12dp"
        android:layout_marginBottom="8dp"
        android:enabled="false"/>

    <LinearLayout
        android:id="@+id/layoutScoreboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/score_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvLiveScore"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="0 : 0"
                android:textSize="42sp"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textColor="#2E7D32"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnAddGoal1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚽ + Гол"
                android:backgroundTint="#4CAF50"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                android:padding="12dp"/>

            <Button
                android:id="@+id/btnAddGoal2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚽ + Гол"
                android:backgroundTint="#F44336"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:layout_marginStart="4dp"
                android:padding="12dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📝 ПОДІЇ МАТЧУ"
            android:textSize="12sp"
            android:textColor="#757575"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <ScrollView
            android:id="@+id/scrollViewEvents"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/events_bg">

            <LinearLayout
                android:id="@+id/layoutEventsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/lineup_bg"
                android:padding="8dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="СКЛАД 1"
                    android:textSize="10sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvLineup1Display"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#333333"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/lineup_bg"
                android:padding="8dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="СКЛАД 2"
                    android:textSize="10sp"
                    android:textColor="#F44336"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"
                    android:gravity="end"/>

                <TextView
                    android:id="@+id/tvLineup2Display"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#333333"
                    android:textAlignment="textEnd"/>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnFinishMatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏁 Завершити матч"
            android:backgroundTint="#F44336"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:padding="12dp"/>

    </LinearLayout>

</LinearLayout>