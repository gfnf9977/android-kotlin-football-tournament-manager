<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/header_gradient"
        android:padding="20dp"
        android:layout_marginBottom="16dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tvLineupTeamName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Формування складу"
            android:textAlignment="center"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚽ Вибір тактики та гравців"
            android:textSize="12sp"
            android:textColor="#E0E0E0"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/group_border"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 ТАКТИЧНА СХЕМА"
            android:textSize="12sp"
            android:textColor="#757575"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spFormation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/spinner_border"
            android:padding="10dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎯 РОЗСТАНОВКА ГРАВЦІВ"
        android:textSize="12sp"
        android:textColor="#757575"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/pitch_bg"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/layoutPositionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center" />
    </ScrollView>

    <Button
        android:id="@+id/btnSaveLineup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✅ Затвердити стартові 11"
        android:layout_marginTop="16dp"
        android:backgroundTint="#2E7D32"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:padding="12dp"/>

</LinearLayout>